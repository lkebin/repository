{{ define "Update" }}
func (r {{ .Receiver }}) {{ .Name }}({{ Params .Params .Repository }}) {{ Results .Results .Repository }} {
	_, err := r.db.ExecContext({{ CtxParam .Params }}, "{{- UpdateClause .TableName .Model -}} {{- WhereClause .WhereColumns -}}", {{ UpdateFieldBinding .Params .Model }})
	if err != nil {
		return err
	}

	return nil
}
{{ end }}
